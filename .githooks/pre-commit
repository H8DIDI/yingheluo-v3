#!/usr/bin/env bash
# pre-commit hook: Security audit before every commit
# Prevents accidental leaks of secrets, personal info, etc.

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

BLOCKED=0
WARNED=0

echo "🔒 Running security audit..."

# Get staged files (only text files that exist)
STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx|json|md|html|css|toml|yaml|yml|env|sh|bat|py|cfg|conf|ini)$' || true)

if [ -z "$STAGED" ]; then
  echo -e "${GREEN}✅ No auditable files staged.${NC}"
  exit 0
fi

# ── 1. Hardcoded API keys / tokens / secrets ──
SECRETS_PATTERN='(sk-[a-zA-Z0-9_-]{20,}|ghp_[a-zA-Z0-9]{36}|gho_[a-zA-Z0-9]{36}|github_pat_[a-zA-Z0-9_]{40,}|xox[bpsa]-[a-zA-Z0-9-]{10,}|AIza[a-zA-Z0-9_-]{35}|AKIA[A-Z0-9]{16}|sk-ant-[a-zA-Z0-9_-]{20,})'

for f in $STAGED; do
  [ -f "$f" ] || continue
  matches=$(git diff --cached -- "$f" | grep '^+' | grep -v '^+++' | grep -oE "$SECRETS_PATTERN" || true)
  if [ -n "$matches" ]; then
    echo -e "${RED}🚨 BLOCKED: Potential secret in $f${NC}"
    echo "$matches" | head -3
    BLOCKED=1
  fi
done

# ── 2. Generic secret patterns (password=, secret=, token= with values) ──
for f in $STAGED; do
  [ -f "$f" ] || continue
  matches=$(git diff --cached -- "$f" | grep '^+' | grep -v '^+++' | grep -iE "(password|secret|api_?key|access_?token)\s*[:=]\s*['\"][^'\"]{8,}" || true)
  if [ -n "$matches" ]; then
    echo -e "${YELLOW}⚠️  WARNING: Possible hardcoded credential in $f${NC}"
    echo "$matches" | head -3
    WARNED=1
  fi
done

# ── 3. Personal info patterns (Chinese phone, ID card, email addresses) ──
PII_PATTERN='(1[3-9][0-9]{9}|[0-9]{6}(19|20)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])[0-9]{3}[0-9Xx])'

for f in $STAGED; do
  [ -f "$f" ] || continue
  matches=$(git diff --cached -- "$f" | grep '^+' | grep -v '^+++' | grep -oE "$PII_PATTERN" || true)
  if [ -n "$matches" ]; then
    echo -e "${YELLOW}⚠️  WARNING: Possible personal info (phone/ID) in $f${NC}"
    echo "$matches" | head -3
    WARNED=1
  fi
done

# ── 4. Private email addresses (not noreply) ──
for f in $STAGED; do
  [ -f "$f" ] || continue
  matches=$(git diff --cached -- "$f" | grep '^+' | grep -v '^+++' | grep -oE '[a-zA-Z0-9._%+-]+@(qq|163|126|sina|hotmail|gmail|outlook|yahoo)\.[a-z]{2,}' || true)
  if [ -n "$matches" ]; then
    echo -e "${YELLOW}⚠️  WARNING: Personal email address in $f${NC}"
    echo "$matches" | head -3
    WARNED=1
  fi
done

# ── 5. .env files should never be committed ──
ENV_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^\.env(\..+)?$' | grep -v '\.example$' || true)
if [ -n "$ENV_FILES" ]; then
  echo -e "${RED}🚨 BLOCKED: .env file(s) staged for commit: $ENV_FILES${NC}"
  BLOCKED=1
fi

# ── 6. Large binary files (>1MB) ──
for f in $(git diff --cached --name-only --diff-filter=ACM); do
  [ -f "$f" ] || continue
  size=$(wc -c < "$f" 2>/dev/null || echo 0)
  if [ "$size" -gt 1048576 ]; then
    echo -e "${YELLOW}⚠️  WARNING: Large file ($((size/1024))KB): $f${NC}"
    WARNED=1
  fi
done

# ── Result ──
echo ""
if [ "$BLOCKED" -eq 1 ]; then
  echo -e "${RED}❌ Commit BLOCKED — fix the issues above.${NC}"
  echo -e "${RED}   Use 'git commit --no-verify' to bypass (not recommended).${NC}"
  exit 1
elif [ "$WARNED" -eq 1 ]; then
  echo -e "${YELLOW}⚠️  Warnings found — please review before pushing.${NC}"
else
  echo -e "${GREEN}✅ Security audit passed.${NC}"
fi

exit 0
