// ============================================================================
// Example 1: 国庆大开场
// ============================================================================

// User Input: "生成方案 国庆大开场，要有排浪和对称效果"

// AI Response:
{
  "version": "advanced-v1",
  "title": "国庆盛典开场秀",
  "duration": 60,
  "theme": "国庆",
  "notes": [
    "采用展翅排浪开场，营造盛大氛围",
    "对称齐射强化视觉冲击",
    "红金配色呼应国庆主题"
  ],
  "commands": [
    {
      "type": "wave",
      "time": 0,
      "pattern": "open_wings",
      "group": "all",
      "duration": 3,
      "shell": "Red_Peony",
      "height": 120,
      "description": "红色牡丹展翅开场"
    },
    {
      "type": "symmetry",
      "time": 5,
      "axis": "center",
      "positions": ["all"],
      "shell": "Gold_Chrysanthemum",
      "delay": 200,
      "description": "对称金菊齐射"
    },
    {
      "type": "wave",
      "time": 10,
      "pattern": "close_in",
      "group": "all",
      "duration": 4,
      "shell": "Red_Strobe",
      "height": 100,
      "description": "红色闪光合拢"
    },
    {
      "type": "cascade",
      "time": 16,
      "positions": ["all"],
      "shell": "Gold_Willow",
      "interval": 300,
      "pattern": "sequential",
      "description": "金色柳树级联"
    },
    {
      "type": "burst",
      "time": 25,
      "group": "all",
      "shell": "Red_Gold_Mix",
      "count": 30,
      "interval": 100,
      "random": true,
      "description": "红金混合爆发"
    },
    {
      "type": "finale",
      "time": 55,
      "shell": "Multi_Color_Burst",
      "waves": 3,
      "waveInterval": 500,
      "description": "三波彩色终场"
    }
  ],
  "assistantMessage": "已为您设计国庆盛典开场秀，采用经典的展翅排浪开场，配合对称齐射和级联效果，营造盛大热烈的氛围。高潮部分使用密集爆发，终场三波齐射收尾。"
}

